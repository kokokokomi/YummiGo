<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sy.mapper.OrdersMapper">

    <resultMap id="BaseResultMap" type="com.sy.entity.Orders">
            <id property="id" column="id" />
            <result property="number" column="number" />
            <result property="status" column="status" />
            <result property="userId" column="user_id" />
        <result property="remark" column="remark" />
        <result property="addressBookId" column="address_book_id" />
            <result property="orderTime" column="order_time" />
            <result property="checkoutTime" column="checkout_time" />
            <result property="payMethod" column="pay_method" />
            <result property="stripePaymentIntentId" column="stripe_payment_intent_id" />
            <result property="stripeSessionId" column="stripe_session_id" />
            <result property="payStatus" column="pay_status" />
            <result property="amount" column="amount" />
            <result property="snapshotPhone" column="snapshot_phone" />
            <result property="snapshotAddress" column="snapshot_address" />
            <result property="snapshotUserName" column="snapshot_user_name" />
            <result property="snapshotConsignee" column="snapshot_consignee" />
            <result property="cancelReason" column="cancel_reason" />
            <result property="rejectionReason" column="rejection_reason" />
            <result property="cancelTime" column="cancel_time" />
            <result property="estimatedDeliveryTime" column="estimated_delivery_time" />
            <result property="deliveryStatus" column="delivery_status" />
            <result property="deliveryTime" column="delivery_time" />
            <result property="packAmount" column="pack_amount" />
            <result property="tablewareNumber" column="tableware_number" />
            <result property="tablewareStatus" column="tableware_status" />
            <result property="totalItems" column="total_items" />
            <result property="summary" column="summary" />
            <result property="firstItemName" column="first_item_name" />
            <result property="firstItemImage" column="first_item_image" />
            <result property="isDeleted" column="is_deleted" />
            <result property="version" column="version" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />

    </resultMap>

    <sql id="Base_Column_List">
        id,number,status,user_id,address_book_id,order_time,
        checkout_time,pay_method,stripe_payment_intent_id,stripe_session_id,pay_status,
        amount,snapshot_phone,snapshot_address,snapshot_user_name,snapshot_consignee,
        cancel_reason,rejection_reason,cancel_time,estimated_delivery_time,delivery_status,
        delivery_time,pack_amount,tableware_number,tableware_status,total_items,
        summary,first_item_name,first_item_image,is_deleted,version
    </sql>
    <select id="countByStatus" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM orders WHERE status = #{status}
    </select>
    <select id="selectOrderVOPage" resultType="com.sy.vo.OrderVO">
        SELECT o.*
        FROM orders o
        WHERE (o.is_deleted = 0 OR o.is_deleted IS NULL)
        <if test="dto.number != null and dto.number != ''">
            AND o.number LIKE CONCAT('%', #{dto.number}, '%')
        </if>
        <if test="dto.payStatus != null">
            AND o.pay_status = #{dto.payStatus}
        </if>
        <if test="dto.status != null">
            AND o.status = #{dto.status}
        </if>
        <if test="dto.phone != null and dto.phone != ''">
            AND o.snapshot_phone LIKE CONCAT('%', #{dto.phone}, '%')
        </if>
        <if test="dto.beginTime != null">
            AND o.order_time &gt;= #{dto.beginTime}
        </if>
        <if test="dto.endTime != null">
            AND o.order_time &lt;= #{dto.endTime}
        </if>
        <if test="dto.userId != null">
            AND o.user_id = #{dto.userId}
        </if>
        ORDER BY o.order_time DESC
    </select>

    <select id="selectOrderStatistics" resultType="com.sy.vo.OrderStatisticsVO">
        SELECT
            IFNULL(SUM(CASE WHEN status = 2 THEN 1 ELSE 0 END), 0) AS toBeConfirmed,
            IFNULL(SUM(CASE WHEN status = 3 THEN 1 ELSE 0 END), 0) AS confirmed,
            IFNULL(SUM(CASE WHEN status = 4 THEN 1 ELSE 0 END), 0) AS deliveryInProgress
        FROM orders
        WHERE (is_deleted = 0 OR is_deleted IS NULL)
    </select>
    <select id="sumByMap" resultType="java.lang.Double">
        SELECT sum(amount) FROM orders
        <where>
            <if test="begin!=null">
                AND order_time &gt; #{begin}
            </if>
            <if test="end!=null">
                AND order_time &lt; #{end}
            </if>
            <if test="status!=null">
                AND status = #{status}
            </if>
        </where>
    </select>
</mapper>
